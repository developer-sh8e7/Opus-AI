# HumanGuard AI local-first configuration
# 1) Copy this file to .env
# 2) Fill local values
# 3) Run: npm run dev
# Railway is optional later only; do not add Railway-only variables for local development.

# Required for local bot login
DISCORD_TOKEN=

# Recommended for slash-command registration or diagnostics (not required for local text-mode startup)
CLIENT_ID=
GUILD_ID=

# Optional: if empty, only server admins/owner can use sensitive commands
AUTHORIZED_ROLE_ID=

# AI provider (optional for bot login, required for AI replies)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_API_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# Optional admin alerting webhook
ADMIN_ALERT_WEBHOOK_URL=

# Local tuning
AI_TIMEOUT_MS=25000
AI_MAX_RETRIES=2

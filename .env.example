DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
AUTHORIZED_ROLE_ID=

# OpenCode Zen — Qwen 3.6 Plus (primary AI provider)
QWEN_API_KEY=
QWEN_MODEL=qwen3.6-plus
QWEN_API_BASE_URL=https://opencode.ai/zen/v1

# Cerebras (first fallback)
CEREBRAS_API_KEY=csk-
CEREBRAS_MODEL=zai-glm-4.7

# Generic OpenAI-compatible fallback (second fallback — e.g. Groq)
FALLBACK_API_KEY=
FALLBACK_API_BASE_URL=https://api.groq.com/openai/v1/chat/completions
FALLBACK_MODEL=llama-3.3-70b-versatile

# Admin alerting (Discord webhook — notified when ALL providers go down)
ADMIN_ALERT_WEBHOOK_URL=

AI_TIMEOUT_MS=25000
AI_MAX_RETRIES=2
